{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gemma4-prompt-builder",
  "version": "0.1.0",
  "identifier": "com.gregtherick.gemma4-prompt-builder",
  "build": {
    "beforeDevCommand": "trunk serve",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "trunk build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Gemma 4 Prompt Builder",
        "width": 1200,
        "height": 850,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
